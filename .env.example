# WebTranslatorr Configuration

# Server settings
WTR_HOST=0.0.0.0
WTR_PORT=9811
# Coloca aquí una clave segura para conectar tus *Arr a este Proxy
WTR_API_KEY=my_super_secret_api_key_here
WTR_LOG_LEVEL=INFO

# Provider enable/disable
WTR_EBOOKELO_ENABLED=true
WTR_EPUBLIBRE_ENABLED=true
WTR_LECTULANDIA_ENABLED=true
WTR_ESPAEBOOK_ENABLED=true
WTR_HOLAEBOOK_ENABLED=true
WTR_ELEJANDRIA_ENABLED=false
WTR_ANNASARCHIVE_ENABLED=true
WTR_GUTENBERG_ENABLED=true
WTR_MEJORTORRENT_ENABLED=true
WTR_DONTORRENT_ENABLED=false

# Provider domains (update if domains change)
WTR_MEJORTORRENT_DOMAIN=https://www42.mejortorrent.eu
WTR_DONTORRENT_DOMAIN=https://dontorrent.reisen
WTR_EBOOKELO_DOMAIN=https://ww2.ebookelo.com
WTR_EPUBLIBRE_DOMAIN=https://epublibre.bid
WTR_LECTULANDIA_DOMAIN=https://ww3.lectulandia.co
WTR_ESPAEBOOK_DOMAIN=https://espaebook.cc
WTR_HOLAEBOOK_DOMAIN=https://holaebook.com
WTR_ELEJANDRIA_DOMAIN=https://www.elejandria.com
WTR_ANNASARCHIVE_DOMAIN=https://annas-archive.org
WTR_GUTENBERG_DOMAIN=https://gutenberg.org

# TMDB API (optional, for IMDb ID resolution)
# Get your free API key at: https://www.themoviedb.org/settings/api
WTR_TMDB_API_KEY=

# Scraping settings
WTR_RATE_LIMIT_PER_SECOND=2.0
WTR_MAX_RETRIES=3
WTR_REQUEST_TIMEOUT=30

# Cache settings
WTR_CACHE_ENABLED=true
WTR_CACHE_TTL_SECONDS=300

# Domain auto-resolution
WTR_DOMAIN_CHECK_INTERVAL=1800
WTR_DOMAIN_VALIDATION_TIMEOUT=10

# Proxy (optional)
WTR_HTTP_PROXY=
